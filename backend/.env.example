# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=veeparts
DB_PASSWORD=veeparts_secret
DB_DATABASE=veeparts

# MongoDB
MONGODB_URI=mongodb://localhost:27017/veeparts_catalog

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRATION=30d

# AWS S3 (for image uploads)
AWS_S3_BUCKET=veeparts-images
AWS_S3_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Payment Gateways
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=

FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=

# AI Service
AI_SERVICE_URL=http://localhost:8000

# Commission
COMMISSION_RATE=0.06
COMMISSION_HOLD_HOURS=48
